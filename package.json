{
  "name": "mymine",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "test:3": "bash scripts/test-3-users.sh",
    "test:3:links": "bash scripts/test-3-users.sh --links-only --no-start",
    "server": "node --watch server/index.js",
    "client": "cd client && npm run dev",
    "build": "npm install --prefix client && npm run build --prefix client",
    "start": "NODE_ENV=production node server/index.js",
    "start:render": "node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  },
  "type": "module"
}
