{
  "name": "mymeet",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter @mymeet/server dev\" \"pnpm --filter @mymeet/web dev\"",
    "dev:server": "pnpm --filter @mymeet/server dev",
    "dev:web": "pnpm --filter @mymeet/web dev",
    "build": "pnpm --filter @mymeet/server build && pnpm --filter @mymeet/web build",
    "db:setup": "pnpm --filter @mymeet/server db:setup",
    "db:generate": "pnpm --filter @mymeet/server db:generate",
    "db:push": "pnpm --filter @mymeet/server db:push",
    "db:studio": "pnpm --filter @mymeet/server db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
